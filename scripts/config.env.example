# scripts/config.env — per-host overrides. Copy to scripts/config.env and edit.
# config.env is gitignored.

# Where projects are created (output of Manager team)
PROJECTS_DIR=$HOME/projects

# Where subagent definitions live (Claude Code reads them on Agent-spawn)
AGENTS_DIR=$HOME/.claude/agents

# Main-agent workspace (contains AGENTS.md, IDENTITY.md, USER.md, TOOLS.md, SOUL.md)
WORKSPACE_DIR=$HOME/.openclaw/workspace

# Mirror of subagent defs for openclaw UI visibility (sync-agents.sh populates this)
WORKSPACES_DIR=$HOME/.openclaw/workspaces

# Per-machine secrets (github_token, trello_*, github_owner, etc.)
SECRETS_DIR=$HOME/.openclaw/secrets

# OpenClaw gateway bind mode: loopback / lan / tailnet
OPENCLAW_BIND=lan
