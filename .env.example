# Copy this file to .env and fill in actual values. Never commit .env.

# LLM (Kie.ai through proxy) — fallback provider for server deployment
KIE_API_KEY=<your-kie-api-key>
KIE_BASE_URL=https://api.kie.ai/claude
PROXY_PORT=4100

# Linear (optional)
LINEAR_API_KEY=<your-linear-api-key>
LINEAR_TEAM_KEY=<TEAM_KEY>
LINEAR_TEAM_ID=<team-uuid>

# GitHub — token with `repo` scope for creating private repos under your owner
GITHUB_TOKEN=<your-ghp-token>
GITHUB_REPO=<owner>/<repo>

# Mission Control (if used)
MC_URL=http://localhost:3100
MC_USER=admin
MC_PASS=<your-mc-password>

# AgentOps (optional telemetry)
AGENTOPS_API_KEY=<your-agentops-key>

# Telegram (optional notifications)
TELEGRAM_TOKEN=<bot-token>
TELEGRAM_CHAT_ID=<chat-id>
